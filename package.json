{
  "name": "@iqx-limited/angular-calendar",
  "version": "1.0.0",
  "description": "A lightweight and elegant Angular calendar component built with Preact and Tailwind CSS.",
  "license": "MIT",
  "author": "IQX",
  "repository": "https://github.com/IQXLimited/angular-calendar",
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "module": "dist/index.mjs",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean && rimraf node_modules pnpm-lock.yaml",
    "dev": "turbo run dev",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "lint": "npx -y eslint",
    "lint:fix": "npx -y eslint --fix",
    "publish:all": "./scripts/publish.sh all",
    "publish:dry": "./scripts/publish.sh all --dry-run",
    "publish:main": "./scripts/publish.sh main",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "version:update": "./scripts/update-versions.sh"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.9.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/react-dom": "^19.2.3",
    "angular-eslint": "^21.2.0",
    "autoprefixer": "^10.4.27",
    "eslint-plugin-import": "^2.32.0",
    "lucide-react": "^0.575.0",
    "oxfmt": "^0.35.0",
    "postcss-import": "^16.1.1",
    "preact": "^10.28.3",
    "react-dom": "^19.2.4",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.2.1",
    "temporal-polyfill": "^0.3.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "volta": {
    "node": "24.14.0"
  },
  "packageManager": "pnpm@8.6.0"
}
