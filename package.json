{
  "name": "@iqx-limited/angular-calendar",
  "version": "0.0.1",
  "description": "A lightweight and elegant Angular calendar component built with Preact and Tailwind CSS.",
  "license": "MIT",
  "author": "IQX",
  "repository": "https://github.com/mattfrank48/angular-calendar",
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:core": "npm run clean && npm i && cd core && tsc -p tsconfig.build.json && rollup -c && rimraf dist/types && mkdir -p ../react-core && cp -r dist/* ../react-core/ && rimraf dist && cp package.json ../react-core/",
    "build:css": "node ./styles/build-css.mjs",
    "build:demo": "ng build --configuration=production",
    "prestart": "npm run build:core && npm i && npm run build:css",
    "start": "ng serve",
    "build": "npm run prestart && ng-packagr -p ng-packagr.json",
    "clean": "rimraf dist node_modules react-core",
    "lint": "npx --yes eslint",
    "lint:fix": "npx --yes eslint --fix",
    "tsc-verify": "tsc --noEmit"
  },
  "main": "dist/fesm2022/iqx-limited-angular-calendar.mjs",
  "module": "dist/fesm2022/iqx-limited-angular-calendar.mjs",
  "typings": "dist/types/iqx-limited-angular-calendar.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/iqx-limited-angular-calendar.d.ts",
      "import": "./dist/fesm2022/iqx-limited-angular-calendar.mjs",
      "default": "./dist/fesm2022/iqx-limited-angular-calendar.mjs"
    },
    "./styles.css": "./dist/styles/styles.css"
  },
  "type": "module",
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@dayflow/blossom-color-picker": "^2.0.1",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@stylistic/eslint-plugin": "^5.9.0",
    "@tailwindcss/postcss": "^4.2.1",
    "angular-eslint": "^21.2.0",
    "autoprefixer": "^10.4.27",
    "identity-obj-proxy": "^3.0.0",
    "lucide-angular": "^0.575.0",
    "lucide-react": "^0.575.0",
    "ng-packagr": "^21.2.0",
    "postcss": "^8.5.6",
    "preact": "^10.28.4",
    "react-core": "file:./react-core",
    "rimraf": "^6.1.3",
    "rollup": "^4.59.0",
    "rollup-plugin-dts": "^6.3.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rxjs": "^7.8.2",
    "tailwindcss": "^4.2.1",
    "temporal-polyfill": "^0.3.0",
    "tsc-alias": "^1.8.16",
    "tslib": "^2.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "peerDependencies": {
    "@angular/common": ">=19.0.0",
    "@angular/core": ">=19.0.0",
    "react-core": "*"
  },
  "volta": {
    "node": "24.14.0"
  }
}
