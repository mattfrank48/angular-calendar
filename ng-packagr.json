{
  "$schema": "./node_modules/ng-packagr/ng-package.schema.json",
  "lib": {
    "entryFile": "src/app/public-api.ts"
  },
  "allowedNonPeerDependencies": [
    "react-core"
  ],
  "assets": [
    "README.md",
    "LICENSE",
    { "glob": "styles.css", "input": "src/", "output": "styles/" },
    { "glob": "**/*", "input": "react-core/", "output": "react-core/" }
  ],
  "dest": "dist"
}
