{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    "baseUrl": ".",
    "paths": {
      "@dayflow/core": ["packages/core/src/index.ts"],
      "@dayflow/angular": ["packages/angular/src/public-api.ts"],
      "@examples/*": ["examples/*"],
      "@/*": ["packages/core/src/*"]
    }
  },
  "include": ["packages/*/src", "examples"],
  "exclude": ["node_modules", "dist"]
}
