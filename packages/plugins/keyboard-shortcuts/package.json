{
  "name": "@angular-calendar/plugin-keyboard-shortcuts",
  "version": "1.0.0",
  "description": "Keyboard shortcuts plugin for Angular Calendar",
  "keywords": [
    "calendar",
    "angular",
    "keyboard",
    "plugin",
    "shortcuts"
  ],
  "license": "MIT",
  "author": "IQX",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json && rollup -c",
    "clean": "rimraf dist node_modules",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@dayflow/core": "^3.1.2",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "rimraf": "^6.1.3",
    "rollup": "^4.59.0",
    "rollup-plugin-dts": "^6.3.0",
    "temporal-polyfill": "^0.3.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@dayflow/core": "^3.1.2"
  },
  "volta": {
    "node": "24.14.0"
  }
}
