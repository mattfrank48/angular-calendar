{
  "name": "@dayflow/angular",
  "version": "3.1.2",
  "description": "Angular adapter for DayFlow calendar",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "dist/fesm2022/dayflow-angular.mjs",
  "module": "dist/fesm2022/dayflow-angular.mjs",
  "typings": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/fesm2022/dayflow-angular.mjs",
      "default": "./dist/fesm2022/dayflow-angular.mjs"
    }
  },
  "scripts": {
    "build": "ng-packagr -p ng-packagr.json",
    "clean": "rimraf dist node_modules",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-browser-dynamic": "^21.2.0",
    "@dayflow/core": "^3.1.2",
    "ng-packagr": "^21.2.0",
    "rimraf": "^6.1.3",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "zone.js": "^0.16.1"
  },
  "peerDependencies": {
    "@angular/common": ">=19.0.0",
    "@angular/core": ">=19.0.0",
    "@dayflow/core": ">=3.0.0"
  },
  "volta": {
    "node": "24.14.0"
  }
}
