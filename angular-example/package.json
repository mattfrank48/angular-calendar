{
  "name": "angular-calendar-example",
  "version": "1.0.0",
  "scripts": {
    "build:css": "node ./build-css.mjs",
    "start": "npm run build:css && ng serve",
    "build": "npm run build:css && ng-packagr -p ng-packagr.json",
    "clean": "rimraf dist node_modules",
    "lint": "npx --yes eslint",
    "lint:fix": "npx --yes eslint --fix",
    "tsc-verify": "tsc --noEmit"
  },
  "main": "dist/fesm2022/dayflow-angular.mjs",
  "module": "dist/fesm2022/dayflow-angular.mjs",
  "typings": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/fesm2022/dayflow-angular.mjs",
      "default": "./dist/fesm2022/dayflow-angular.mjs"
    },
    "./styles.css": "./dist/styles/styles.css"
  },
  "type": "module",
  "private": true,
  "packageManager": "pnpm@8.6.0",
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@dayflow/blossom-color-picker": "^2.0.1",
    "@dayflow/core": "^3.1.2",
    "@stylistic/eslint-plugin": "^5.9.0",
    "@tailwindcss/postcss": "^4.2.1",
    "angular-eslint": "^21.2.0",
    "autoprefixer": "^10.4.27",
    "lucide-angular": "^0.575.0",
    "ng-packagr": "^21.2.0",
    "postcss": "^8.5.6",
    "rxjs": "^7.8.2",
    "tailwindcss": "^4.2.1",
    "temporal-polyfill": "^0.3.0",
    "tslib": "^2.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "peerDependencies": {
    "@angular/common": ">=19.0.0",
    "@angular/core": ">=19.0.0",
    "@dayflow/core": ">=19.0.0"
  }
}
